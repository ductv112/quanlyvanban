# ============================================
# QLVB Backend — Environment Variables
# Copy file này thành .env rồi điền giá trị thật
# ============================================

# --- Server ---
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# --- PostgreSQL ---
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=qlvb_dev
PG_USER=qlvb_admin
PG_PASSWORD=your_pg_password
PG_MAX_CONNECTIONS=20

# --- MongoDB (Log & Audit) ---
MONGODB_URI=mongodb://qlvb_admin:your_mongo_password@localhost:27017/qlvb_logs?authSource=admin

# --- Redis (Cache + BullMQ) ---
# Redis dùng cho:
#   1. Cache (lib/redis/client.ts) — hash sessions, rate limits
#   2. BullMQ backing store (lib/queue/*) — LGSP, notification, signing queue (Phase 11+)
#
# Có thể dùng 1 trong 2 cách cấu hình:
#   - REDIS_URL (URI, ưu tiên cho production): redis://[:password@]host:port[/db]
#   - REDIS_HOST + REDIS_PORT + REDIS_PASSWORD (legacy/dev, dưới đây)
#
# Khi deploy production: khuyến nghị Redis persistent (appendonly yes) để job
# signing survive khi Redis restart — BullMQ dựa vào Redis data để resume
# pending poll jobs (3 phút window per sign transaction).
# REDIS_URL=redis://:password@redis-host:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# --- MinIO (File Storage) ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=qlvb_admin
MINIO_SECRET_KEY=your_minio_password
MINIO_USE_SSL=false
MINIO_BUCKET=documents

# --- JWT Auth ---
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# --- Signing (pgcrypto key for client_secret encryption — Phase 8+) ---
# Key dùng để pgp_sym_encrypt/decrypt provider client_secret trong DB.
# Tối thiểu 16 ký tự (khuyến nghị 32+ ký tự ngẫu nhiên).
# Mất key = không decrypt được client_secret đã lưu — BACKUP KEY an toàn!
SIGNING_SECRET_KEY=change-this-to-a-random-32-chars-key-in-production
